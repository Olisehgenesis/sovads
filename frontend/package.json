{
  "name": "sovads",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sdk:build": "tsc --project ../sdk/tsconfig.json --outDir ./src/_sovads_sdk",
    "sdk:watch": "tsc --project ../sdk/tsconfig.json --outDir ./src/_sovads_sdk --watch --preserveWatchOutput",
    "dev": "pnpm sdk:build && concurrently -k -n sdk,next -c yellow,cyan \"pnpm sdk:watch\" \"dotenvx run -- next dev --turbopack\"",
    "build": "dotenvx run -- prisma generate && dotenvx run -- next build",
    "start": "dotenvx run -- next start",
    "start:system": "dotenvx run -- tsx scripts/start-system.ts",
    "testconnection": "dotenvx run -- tsx scripts/test-connection.ts",
    "generate-connection": "dotenvx run -- tsx scripts/generate-connection.ts",
    "test": "dotenvx run -- node --test --experimental-strip-types src/lib/**/*.test.ts",
    "lint": "dotenvx run -- eslint",
    "db:generate": "dotenvx run -- prisma generate",
    "db:push": "dotenvx run -- prisma db push",
    "db:migrate": "dotenvx run -- prisma migrate dev",
    "db:studio": "dotenvx run -- prisma studio",
    "db:migrate-from-mongo": "dotenvx run -- tsx scripts/migrate-mongo-to-prisma.ts",
    "db:migrate-from-mongo:dry": "DRY_RUN=1 dotenvx run -- tsx scripts/migrate-mongo-to-prisma.ts",
    "db:reconcile": "dotenvx run -- tsx scripts/reconcile-spend.ts",
    "db:reconcile:fix": "dotenvx run -- tsx scripts/reconcile-spend.ts --fix",
    "drizzle:generate": "dotenvx run -- drizzle-kit generate",
    "drizzle:push": "dotenvx run -- drizzle-kit push",
    "drizzle:studio": "dotenvx run -- drizzle-kit studio",
    "turso:smoke": "dotenvx run -- tsx scripts/turso-smoke.ts",
    "turso:smoke:migration": "dotenvx run -- tsx scripts/turso-smoke-migration.ts",
    "interactions:smoke": "dotenvx run -- tsx scripts/interactions-smoke.ts",
    "serve:smoke": "dotenvx run -- tsx scripts/serve-smoke.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@goodsdks/engagement-sdk": "^1.0.4",
    "@libsql/client": "^0.17.4",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/client": "6",
    "@reown/appkit": "^1.8.18",
    "@reown/appkit-adapter-wagmi": "^1.8.18",
    "@tanstack/react-query": "^5.90.21",
    "@types/mdx": "^2.0.14",
    "@wagmi/core": "^2.22.1",
    "bullmq": "^5.70.1",
    "cloudinary": "^2.9.0",
    "dgram": "^1.0.1",
    "dns": "^0.2.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "fumadocs-core": "^16.10.5",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.5",
    "lz-string": "^1.5.0",
    "mongodb": "^6.21.0",
    "next": "^16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.7.0",
    "sovads-sdk": "^1.1.1",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.46.3",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss-custom-properties": "^15.0.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@reown/appkit": "^1.8.18",
      "@reown/appkit-pay": "^1.8.18",
      "@reown/appkit-ui": "^1.8.18",
      "@reown/appkit-scaffold-ui": "^1.8.18",
      "@reown/appkit-common": "^1.8.18",
      "@reown/appkit-controllers": "^1.8.18",
      "@reown/appkit-utils": "^1.8.18",
      "@reown/appkit-wallet": "^1.8.18"
    }
  }
}